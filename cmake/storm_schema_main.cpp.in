// Auto-generated by storm_enable_migrations() — do not edit.
// import std; migration (issue #326): textual <meta> MUST precede the imports —
// textual libc++ headers reached via <meta> redefine entities the std module
// owns if the module is imported first. `import storm;` transitively imports
// std, so all textual std headers (incl. those in model headers) must come
// before it. import std; supplies <array>/<fstream>/<string>/etc.; <meta> stays
// textual because import std; does not export std::meta:: (issue #326 Finding A).
#include <meta>

import storm;
import std;

// User's model headers — contain struct definitions with storm attributes.
// (storm:: attributes require the storm module to be imported first.)
@STORM_MODELS_INCLUDES@

namespace {

// ── Compile-time namespace reflection ───────────────────────────────────────

consteval auto count_models() -> std::size_t {
    std::size_t count = 0;
    for (auto member : std::meta::members_of(^^@STORM_MODELS_NAMESPACE@, std::meta::access_context::unchecked())) {
        if (std::meta::is_type(member) && std::meta::is_class_type(member)) {
            for (auto dm : std::meta::nonstatic_data_members_of(member, std::meta::access_context::unchecked())) {
                auto attr = std::meta::annotation_of_type<storm::meta::FieldAttr>(dm);
                if (attr.has_value() && attr.value() == storm::meta::FieldAttr::primary) {
                    ++count;
                    break;
                }
            }
        }
    }
    return count;
}

consteval auto get_model_infos() -> std::array<std::meta::info, count_models()> {
    std::array<std::meta::info, count_models()> result{};
    std::size_t idx = 0;
    for (auto member : std::meta::members_of(^^@STORM_MODELS_NAMESPACE@, std::meta::access_context::unchecked())) {
        if (std::meta::is_type(member) && std::meta::is_class_type(member)) {
            for (auto dm : std::meta::nonstatic_data_members_of(member, std::meta::access_context::unchecked())) {
                auto attr = std::meta::annotation_of_type<storm::meta::FieldAttr>(dm);
                if (attr.has_value() && attr.value() == storm::meta::FieldAttr::primary) {
                    result[idx++] = member;
                    break;
                }
            }
        }
    }
    return result;
}

// ── Schema emission ─────────────────────────────────────────────────────────

template <std::meta::info M>
void emit_one(std::ostream &out, storm::orm::schema::Dialect dialect) {
    using T = [:M:];
    if (dialect == storm::orm::schema::Dialect::PostgreSQL) {
        out << storm::create_table_sql<T, storm::orm::schema::Dialect::PostgreSQL>();
    } else {
        out << storm::create_table_sql<T>();
    }
    out << ";\n";
    for (const auto &idx_sql : storm::create_index_sql<T>()) {
        out << idx_sql << ";\n";
    }
    out << "\n";
}

template <std::size_t... Is>
void emit_all(std::ostream &out, storm::orm::schema::Dialect dialect, std::index_sequence<Is...>) {
    constexpr auto models = get_model_infos();
    (emit_one<models[Is]>(out, dialect), ...);
}

void emit_namespace_schemas(std::ostream &out, storm::orm::schema::Dialect dialect) {
    emit_all(out, dialect, std::make_index_sequence<count_models()>{});
}

// ── CLI ─────────────────────────────────────────────────────────────────────

struct Options {
    storm::orm::schema::Dialect dialect = storm::orm::schema::Dialect::SQLite;
    std::string output_file;
};

auto parse_args(int argc, char *argv[]) -> Options {
    Options opts;
    for (int i = 1; i < argc; ++i) {
        std::string_view arg = argv[i];
        if (arg == "--dialect" && i + 1 < argc) {
            std::string_view val = argv[++i];
            if (val == "postgresql" || val == "pg") {
                opts.dialect = storm::orm::schema::Dialect::PostgreSQL;
            } else if (val == "sqlite") {
                opts.dialect = storm::orm::schema::Dialect::SQLite;
            } else {
                std::cerr << "Unknown dialect: " << val << " (use sqlite or postgresql)\n";
                std::exit(1);
            }
        } else if (arg == "--output" && i + 1 < argc) {
            opts.output_file = argv[++i];
        } else if (arg == "--help" || arg == "-h") {
            std::cout << "Usage: @STORM_SCHEMA_TARGET@ [OPTIONS]\n"
                      << "\n"
                      << "Generate Atlas-compatible SQL schema from Storm ORM models.\n"
                      << "Auto-discovers models in namespace '@STORM_MODELS_NAMESPACE@'.\n"
                      << "\n"
                      << "Options:\n"
                      << "  --dialect sqlite|postgresql  SQL dialect (default: sqlite)\n"
                      << "  --output FILE                Write to file instead of stdout\n"
                      << "  -h, --help                   Show this help\n";
            std::exit(0);
        } else {
            std::cerr << "Unknown argument: " << arg << "\n";
            std::exit(1);
        }
    }
    return opts;
}

} // namespace

auto main(int argc, char *argv[]) -> int {
    auto opts = parse_args(argc, argv);

    std::ofstream file_out;
    if (!opts.output_file.empty()) {
        file_out.open(opts.output_file);
        if (!file_out) {
            std::cerr << "Cannot open output file: " << opts.output_file << "\n";
            return 1;
        }
    }

    std::ostream &out = opts.output_file.empty() ? std::cout : file_out;

    out << "-- Storm ORM schema (auto-generated)\n";
    out << "-- Dialect: "
        << (opts.dialect == storm::orm::schema::Dialect::PostgreSQL ? "PostgreSQL" : "SQLite")
        << "\n\n";

    emit_namespace_schemas(out, opts.dialect);

    return 0;
}
