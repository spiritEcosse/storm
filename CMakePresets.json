{
  "version": 4,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "${sourceDir}/../clang-p2996/build/bin/clang",
        "CMAKE_CXX_COMPILER": "${sourceDir}/../clang-p2996/build/bin/clang++",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "${sourceDir}/../clang-p2996/build/bin/clang-scan-deps",
        "LIBCXX_ROOT": "${sourceDir}/../clang-p2996"
      }
    },
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug",
      "description": "Debug build with tests and coverage",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_TESTS": "ON",
        "ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release (dev)",
      "description": "Release build with tests and benchmarks — for development and CI",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_TESTS": "ON",
        "ENABLE_BENCH": "ON"
      }
    },
    {
      "name": "ninja-prod",
      "displayName": "Ninja Production",
      "description": "Optimised Release build — no tests, no benchmarks, no coverage",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/prod",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ninja-debug",
      "configurePreset": "ninja-debug"
    },
    {
      "name": "ninja-release",
      "configurePreset": "ninja-release"
    },
    {
      "name": "ninja-prod",
      "configurePreset": "ninja-prod"
    }
  ],
  "testPresets": [
    {
      "name": "ninja-debug",
      "configurePreset": "ninja-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ninja-release",
      "configurePreset": "ninja-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
