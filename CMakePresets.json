{
  "version": 4,
  "configurePresets": [
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug",
      "description": "Use Ninja generator with Debug build type",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_STANDARD": "26",
        "CMAKE_C_COMPILER": "${sourceDir}/../clang-p2996/build/bin/clang",
        "CMAKE_CXX_COMPILER": "${sourceDir}/../clang-p2996/build/bin/clang++",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "${sourceDir}/../clang-p2996/build/bin/clang-scan-deps",
        "LIBCXX_ROOT": "${sourceDir}/../clang-p2996"
      }
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release",
      "description": "Use Ninja generator with Release build type",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_STANDARD": "26",
        "CMAKE_C_COMPILER": "${sourceDir}/../clang-p2996/build/bin/clang",
        "CMAKE_CXX_COMPILER": "${sourceDir}/../clang-p2996/build/bin/clang++",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "${sourceDir}/../clang-p2996/build/bin/clang-scan-deps",
        "LIBCXX_ROOT": "${sourceDir}/../clang-p2996"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ninja-debug",
      "configurePreset": "ninja-debug"
    },
    {
      "name": "ninja-release",
      "configurePreset": "ninja-release"
    }
  ]
}
